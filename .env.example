# ─── Musaic Environment Variables ────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored by Vite by default.

# Your Spotify app's Client ID (from https://developer.spotify.com/dashboard)
VITE_SPOTIFY_CLIENT_ID=your_client_id_here

# OAuth redirect URI — must match exactly what's registered in your Spotify app
# Default for local dev:
VITE_REDIRECT_URI=https://127.0.0.1:5173/callback
